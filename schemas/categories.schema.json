{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bazar-khata/data/schemas/categories.schema.json",
  "title": "Bazar Khata Categories Document",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "datasetVersion", "generatedAt", "categories"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "datasetVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" }
    }
  },
  "$defs": {
    "localizedName": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "bn"],
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "bn": { "type": "string", "minLength": 1 }
      }
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "name",
        "icon",
        "color",
        "backgroundColor",
        "sortOrder",
        "isActive",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "$ref": "#/$defs/localizedName" },
        "icon": { "type": "string", "minLength": 1 },
        "color": { "type": "string", "pattern": "^#[0-9A-F]{6}$" },
        "backgroundColor": { "type": "string", "pattern": "^#[0-9A-F]{6}$" },
        "sortOrder": { "type": "integer", "minimum": 1 },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
